{
  "name": "photo-album-organizer",
  "version": "1.0.0",
  "description": "Locally-run photo album organizer — Vite + vanilla JS + Fastify + SQLite",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\" --names \"vite,api\" --prefix-colors \"cyan,yellow\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/integration",
    "lint": "eslint src server --ext .js",
    "lint:fix": "eslint src server --ext .js --fix",
    "format": "prettier --write src server"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^11.0.0",
    "exifr": "^7.1.3",
    "fastify": "^5.0.0",
    "photo-album-organizer": "file:"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
